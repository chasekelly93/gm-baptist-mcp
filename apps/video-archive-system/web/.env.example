# Public, client-side Supabase config (safe to expose in the browser bundle).
# Get these from Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# Which organizations row this deployment serves — see schema.sql.
VITE_DEFAULT_ORG_SLUG=gm_baptist_outreach

# n8n webhook that drafts a title/description/category from a pasted Loom
# link (see the n8n workflow export in this app's chat history / README).
# Use the /webhook/ (production, no "-test") URL once the workflow is
# activated in n8n — the /webhook-test/ URL only fires once per click of
# "Listen for test event" in the n8n editor.
VITE_ANALYZE_LOOM_WEBHOOK_URL=https://n8n.gmbaptistoutreach.com/webhook/analyze-loom-video
