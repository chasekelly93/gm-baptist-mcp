# =============================================================================
# n8n Droplet Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Domain — the subdomain you'll point to your Droplet IP
N8N_HOST=n8n.gmbaptistoutreach.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.gmbaptistoutreach.com/

# Basic auth — protects the n8n UI until you configure SSO or more
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Timezone
GENERIC_TIMEZONE=America/New_York

# n8n encryption key — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# Let's Encrypt SSL certificate email
SSL_EMAIL=chase@gmbaptistoutreach.com

# Optional: GitHub token for automated workflow backups
# Generate at https://github.com/settings/tokens (scope: repo)
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=chasekelly93/gmb-n8n-backups
