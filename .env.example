# Agency-level API key (for sub-account listing)
GHL_API_KEY=your_agency_api_key_here

# Location-level API key (for contacts, conversations, messages)
GHL_LOCATION_API_KEY=your_location_api_key_here

# Primary location ID — calls for this location use GHL_LOCATION_API_KEY; all others use GHL_API_KEY
PRIMARY_LOCATION_ID=your_primary_location_id_here

# Supabase — used by /seed-supabase to populate the clients table
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
